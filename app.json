{
  "expo": {
    "name": "FutFinder",
    "slug": "futfinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#201F1D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.futfinder.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FutFinder usa tu ubicación para mostrarte partidos cerca y confirmar tu asistencia."
      }
    },
    "android": {
      "package": "com.futfinder.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.RECORD_AUDIO"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#71B533",
      "androidMode": "default",
      "androidCollapsedTitle": "FutFinder",
      "iosDisplayInForeground": true
    },
    "web": {
      "bundler": "metro",
      "name": "FutFinder",
      "shortName": "FutFinder",
      "themeColor": "#71B533",
      "backgroundColor": "#201F1D"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FutFinder usa tu ubicación para mostrarte partidos cerca y confirmar tu asistencia."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FutFinder necesita acceso a tus fotos para que puedas subir tu foto de perfil y portadas de partidos.",
          "cameraPermission": "FutFinder usa tu cámara para que puedas tomar fotos de perfil."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#71B533",
          "defaultChannel": "default",
          "sounds": []
        }
      ]
    ],
    "scheme": "futfinder",
    "extra": {
      "eas": {
        "projectId": "254ce906-c402-456b-80df-8e060a10b09b"
      }
    },
    "owner": "futfinder"
  }
}
